{
  "schemaVersion": 1,
  "id": "dialog-auth",
  "version": "${version}",
  "name": "DialogAuth",
  "description": "A modern, secure authentication system for Minecraft servers using native dialog windows",
  "authors": ["Stepan1411"],
  "contact": {
    "homepage": "https://modrinth.com/mod/dialog-auth",
    "issues": "https://github.com/stepan1411/dialog-auth/issues"
  },
  "license": "MIT",
  "icon": "assets/dialog-auth/icon.png",
  "environment": "server",
  "entrypoints": {
    "fabric-datagen": [
      "org.stepan1411.dialogAuth.client.DialogAuthDataGenerator"
    ],
    "main": [
      "org.stepan1411.dialogAuth.DialogAuth"
    ]
  },
  "mixins": [
    "dialog-auth.mixins.json",
    {
      "config": "dialog-auth.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": ">=1.21.6"
  }
}
